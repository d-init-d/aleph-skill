{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aleph.local/schemas/2.0/numerical-propagation-trace-row.schema.json",
  "allOf": [
    {"$ref": "propagation-trace-row.schema.json"},
    {
      "required": [
        "run_id",
        "tick",
        "source_tick",
        "source_state",
        "target_state",
        "sampled_strength"
      ],
      "properties": {
        "noise": {"const": 0},
        "sample_refs": {
          "type": "array",
          "minItems": 1,
          "maxItems": 1,
          "items": {"type": "string", "pattern": "^run:[0-9]{1,20}$"}
        }
      }
    }
  ]
}
