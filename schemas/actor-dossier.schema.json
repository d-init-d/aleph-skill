{
  "$schema": "https://json-schema.org/draft/2020-12/schema", "$id": "https://aleph.local/schemas/2.0/actor-dossier.schema.json",
  "type": "object", "additionalProperties": false,
  "required": ["id", "person_node", "public_role", "scope_note", "materiality", "subject_class", "evidence_ids"],
  "properties": {
    "id": {"type": "string", "pattern": "^actor:"}, "person_node": {"type": "string", "pattern": "^entity:"},
    "public_role": {"type": "string"}, "scope_note": {"type": "string"}, "materiality": {"enum": ["material", "non_material"]},
    "subject_class": {"enum": ["public_role_person", "private_person", "minor", "unknown"]}, "living_status": {"type": "string"},
    "evidence_ids": {"type": "array", "minItems": 1, "items": {"type": "string", "pattern": "^evidence:"}},
    "research_track": {"type": "object"}, "roleplay_track": {"type": "object"}, "adjudication": {"type": "object"},
    "decision_graph": {"anyOf": [{"type": "object"}, {"type": "array"}]}, "decision_patterns": {"type": "array"},
    "predicted_responses": {"type": "array"}, "biographical_foundation": {"type": "object"}, "stated_beliefs": {"type": "array"},
    "institutional_constraints": {"type": "array"}, "relationships": {"type": "array"}, "crisis_behavior": {"type": "object"},
    "uncertainty_factors": {"type": "array"}
  }
}
