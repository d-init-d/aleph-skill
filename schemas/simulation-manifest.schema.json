{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aleph.local/schemas/2.0/simulation-manifest.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "simulation_id", "created_at", "status", "likelihood_mode", "simulation_mode", "change_point", "temporal_frame", "scope", "execution", "assumptions", "artifact_paths"],
  "properties": {
    "schema_version": {"const": "2.0.0"},
    "simulation_id": {"type": "string", "pattern": "^sim[-:]"},
    "created_at": {"type": "string", "format": "date-time"},
    "status": {"enum": ["draft", "complete", "completed"]},
    "assurance_tier": {"type": ["string", "null"], "enum": ["experimental", "limited", "verified", "calibrated", null]},
    "likelihood_mode": {"enum": ["deterministic", "relative_weight", "calibrated_probability"]},
    "simulation_mode": {"enum": ["qualitative", "deterministic", "monte_carlo"]},
    "change_point": {
      "type": "object", "additionalProperties": false,
      "required": ["type", "target", "description", "magnitude", "time", "location", "assumption_ref"],
      "properties": {
        "type": {"type": "string"}, "target": {"type": "string"}, "description": {"type": "string"},
        "magnitude": {"type": "number"}, "time": {"type": "string"}, "location": {"type": "string"},
        "assumption_ref": {"type": "string", "pattern": "^assumption:"}
      }
    },
    "temporal_frame": {
      "type": "object", "additionalProperties": false,
      "required": ["mode", "observation_cutoff", "simulation_start", "simulation_end", "future_projection"],
      "properties": {
        "mode": {"enum": ["retrospective_counterfactual", "prospective_intervention", "hybrid_projection"]},
        "observation_cutoff": {"type": "string"}, "simulation_start": {"type": "string"}, "simulation_end": {"type": "string"},
        "future_projection": {"type": "boolean"}, "calibration_strategy": {"type": "string"},
        "monitoring_indicators": {"type": "array", "items": {"type": "string"}}
      }
    },
    "scope": {
      "type": "object", "additionalProperties": false, "required": ["horizon", "domains", "geographies"],
      "properties": {
        "horizon": {"type": "string"}, "domains": {"type": "array", "minItems": 1, "items": {"type": "string"}},
        "geographies": {"type": "array", "minItems": 1, "items": {"type": "string"}}
      }
    },
    "execution": {
      "type": "object", "additionalProperties": false,
      "required": ["adaptive_scope", "research_quality", "research_control", "d_research", "subagents", "checkpoints"],
      "properties": {
        "adaptive_scope": {
          "type": "object", "additionalProperties": false, "required": ["assessed", "overall_complexity", "dimensions", "rationale", "decomposition"],
          "properties": {
            "assessed": {"type": "boolean"}, "overall_complexity": {"type": "number", "minimum": 0, "maximum": 1}, "rationale": {"type": "string"},
            "dimensions": {"type": "object", "additionalProperties": false, "required": ["temporal_span", "domain_breadth", "geographic_breadth", "actor_density", "causal_depth", "evidence_uncertainty", "stakes"], "properties": {"temporal_span": {"type": "number", "minimum": 0, "maximum": 1}, "domain_breadth": {"type": "number", "minimum": 0, "maximum": 1}, "geographic_breadth": {"type": "number", "minimum": 0, "maximum": 1}, "actor_density": {"type": "number", "minimum": 0, "maximum": 1}, "causal_depth": {"type": "number", "minimum": 0, "maximum": 1}, "evidence_uncertainty": {"type": "number", "minimum": 0, "maximum": 1}, "stakes": {"type": "number", "minimum": 0, "maximum": 1}}},
            "decomposition": {"type": "object", "additionalProperties": false, "required": ["subquestions", "critical_paths", "research_waves_completed"], "properties": {"subquestions": {"type": "array", "items": {"type": "string"}}, "critical_paths": {"type": "array", "items": {"type": "string"}}, "research_waves_completed": {"type": "integer", "minimum": 0}}}
          }
        },
        "research_quality": {"enum": ["best-available", "limited", "unknown"]},
        "research_control": {"type": "object", "additionalProperties": false, "required": ["policy", "sources_examined", "saturation_reached", "unresolved_critical_gaps"], "properties": {"policy": {"const": "evidence-saturation"}, "sources_examined": {"type": "integer", "minimum": 0}, "saturation_reached": {"type": "boolean"}, "consecutive_no_new_material_claims": {"type": "integer", "minimum": 0}, "stop_reason": {"type": "string"}, "unresolved_critical_gaps": {"type": "array", "items": {"type": "string"}}, "next_wave_queue": {"type": "array", "items": {"type": "string", "minLength": 1}}}},
        "d_research": {
          "type": "object", "additionalProperties": false, "required": ["status", "invoked"],
          "properties": {
            "status": {"enum": ["unknown", "unavailable", "incompatible", "available", "imported", "verified"]},
            "invoked": {"type": "boolean"}, "path": {"type": "string", "minLength": 1},
            "package_major": {"const": 3}, "ledger_ref": {"type": "string", "minLength": 1}
          },
          "allOf": [
            {"if": {"properties": {"status": {"enum": ["unknown", "unavailable", "incompatible"]}}}, "then": {"properties": {"invoked": {"const": false}}}},
            {"if": {"properties": {"status": {"const": "available"}}}, "then": {"required": ["path", "package_major"]}},
            {"if": {"properties": {"status": {"enum": ["imported", "verified"]}}}, "then": {"required": ["path", "package_major", "ledger_ref"], "properties": {"invoked": {"const": true}}}}
          ]
        },
        "subagents": {"type": "object", "additionalProperties": false, "required": ["status"], "properties": {"status": {"type": "string"}, "tool": {"type": ["string", "null"]}, "detection_method": {"type": "string"}, "fallback_reason": {"type": "string"}}},
        "repair_cycles_completed": {"type": "integer", "minimum": 0},
        "checkpoints": {"type": "object", "additionalProperties": false, "required": ["initialized", "scope_assessed", "baseline_researched", "human_tracks_completed", "graph_built", "propagated", "branched", "validated"], "properties": {"initialized": {"type": "boolean"}, "scope_assessed": {"type": "boolean"}, "baseline_researched": {"type": "boolean"}, "human_tracks_completed": {"type": "boolean"}, "graph_built": {"type": "boolean"}, "propagated": {"type": "boolean"}, "branched": {"type": "boolean"}, "validated": {"type": "boolean"}}}
      }
    },
    "artifact_paths": {
      "type": "object", "additionalProperties": false,
      "properties": {
        "nodes": {"type": "string"}, "edges": {"type": "string"}, "actors": {"type": "string"}, "human_track_ledger": {"type": "string"}, "evidence_map": {"type": "string"}, "branch_ledger": {"type": "string"}, "propagation_trace": {"type": "string"}, "validation_report": {"type": "string"}, "quality_report": {"type": "string"}, "final_report": {"type": "string"}, "computational_model": {"type": "string"}, "simulation_config": {"type": "string"}, "run_manifest": {"type": "string"}, "run_ledger": {"type": "string"}, "replay_report": {"type": "string"}, "sensitivity_report": {"type": "string"}, "calibration_report": {"type": "string"}, "roleplay_receipts": {"type": "string"}, "research_import_receipt": {"type": "string"}
      }
    },
    "artifact_index": {"type": "array", "items": {"type": "object", "additionalProperties": false, "required": ["path", "media_type", "size", "sha256", "hash_scope"], "properties": {"path": {"type": "string"}, "media_type": {"type": "string"}, "size": {"type": "integer", "minimum": 0}, "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}, "hash_scope": {"enum": ["full_file", "manifest_input_contract"]}}}},
    "validation_receipt": {"$ref": "#/$defs/receipt_ref"}, "quality_receipt": {"$ref": "#/$defs/receipt_ref"},
    "finalization": {"type": "object", "additionalProperties": false, "required": ["status", "committed_at", "transaction_id"], "properties": {"status": {"const": "committed"}, "committed_at": {"type": "string", "format": "date-time"}, "transaction_id": {"type": "string"}}},
    "migration": {"type": "object", "additionalProperties": false, "required": ["source_schema_version", "target_schema_version", "source_digest", "transforms", "unresolved_fields"], "properties": {"source_schema_version": {"type": "string"}, "target_schema_version": {"const": "2.0.0"}, "source_digest": {"type": "string", "pattern": "^[0-9a-f]{64}$"}, "transforms": {"type": "array", "items": {"type": "string"}}, "unresolved_fields": {"type": "array", "items": {"type": "object"}}}},
    "active_contexts": {"type": "array", "items": {"type": "string"}},
    "assumptions": {"type": "array", "minItems": 1, "items": {"type": "object", "additionalProperties": false, "required": ["id", "statement"], "properties": {"id": {"type": "string", "pattern": "^assumption:"}, "statement": {"type": "string", "minLength": 1}}}}
  },
  "allOf": [
    {
      "if": {"properties": {"status": {"enum": ["complete", "completed"]}}, "required": ["status"]},
      "then": {
        "properties": {
          "execution": {
            "properties": {
              "adaptive_scope": {"properties": {"assessed": {"const": true}}},
              "research_quality": {"enum": ["best-available", "limited"]}
            }
          }
        }
      }
    }
  ],
  "$defs": {
    "receipt_ref": {"type": "object", "additionalProperties": false, "required": ["path", "sha256"], "properties": {"path": {"type": "string"}, "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}, "bundle_digest": {"type": "string", "pattern": "^[0-9a-f]{64}$"}, "assurance_tier": {"type": ["string", "null"]}}}
  }
}
