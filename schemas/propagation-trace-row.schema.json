{
  "$schema": "https://json-schema.org/draft/2020-12/schema", "$id": "https://aleph.local/schemas/2.0/propagation-trace-row.schema.json",
  "type": "object", "additionalProperties": false,
  "required": ["step", "time", "edge_id", "from", "to", "input_effect", "output_effect", "noise", "mechanism", "evidence_ids", "formula_version", "sample_refs", "hash_chain"],
  "properties": {
    "step": {"type": "integer", "minimum": 1}, "time": {"type": "string"}, "edge_id": {"type": "string", "pattern": "^(causal|edge):"},
    "from": {"type": "string"}, "to": {"type": "string"}, "input_effect": {"type": "number"}, "input_change": {"type": "number"},
    "output_effect": {"type": "number"}, "noise": {"type": "number"}, "amplification": {"type": "number"}, "amplification_ratio": {"type": "number"},
    "mechanism": {"type": "string"}, "evidence_ids": {"type": "array", "items": {"type": "string", "pattern": "^evidence:"}},
    "formula_version": {"const": "2.0.0"}, "butterfly_pattern": {"type": "string"},
    "sample_refs": {"type": "array", "minItems": 1, "items": {"type": "string", "maxLength": 128}},
    "run_id": {"type": "integer", "minimum": 0}, "tick": {"type": "integer", "minimum": 0},
    "source_tick": {"type": "integer", "minimum": 0}, "source_state": {"type": "number"},
    "target_state": {"type": "number"}, "sampled_strength": {"type": "number"},
    "hash_chain": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
  }
}
